{
  "name": "logthread",
  "version": "0.1.0",
  "description": "LogThread is an open-source, local-first browser extension for exporting currently viewed AI chats to local files.",
  "type": "module",
  "private": true,
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build && vite build --config vite.content.config.ts",
    "package": "node scripts/package-extension.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "icons:build": "node scripts/build-icons.mjs",
    "icons:check": "node scripts/check-palette.mjs",
    "palette:check": "node scripts/check-palette.mjs",
    "site:build": "node scripts/build-site.mjs",
    "store-assets:build": "node scripts/build-store-assets.mjs",
    "check:content-script": "node scripts/check-content-script-classic.mjs",
    "check:preview": "node scripts/check-preview-build.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm icons:check && pnpm build && pnpm check:content-script && pnpm check:preview && pnpm site:build"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "preact": "^10.27.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@preact/preset-vite": "^2.10.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.1.32",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  }
}
